# PORT: The port the server will listen on.
# For local deployment, you can change this to 7070.
# In AI Studio, this should be 3000.
PORT=7070

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:7070"

# DATABASE_URL: PostgreSQL connection string (Recommended for Vercel/Supabase)
# Example: postgresql://user:password@host:port/database
# DATABASE_URL=

# Alternatively, define individual variables:
# PGHOST=
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# PGPORT=5432
